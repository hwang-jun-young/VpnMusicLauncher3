<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="YTmusic"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="#FF4444" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#141420"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/statusIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏸"
                    android:textSize="48sp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="시작 버튼을 눌러주세요"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="16dp"
                    android:indeterminate="true"
                    android:progressTint="#FF4444"
                    android:visibility="gone" />

                <!-- 연결된 서버 IP + 저장 버튼 -->
                <LinearLayout
                    android:id="@+id/layoutConnectedServer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvConnectedIp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="#44FF44"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnSaveServer"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:text="💾 저장"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#224422"
                        android:stateListAnimator="@null" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 연결 시작 + 취소 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="▶  연결 시작"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF4444"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="80dp"
                android:layout_height="64dp"
                android:layout_marginStart="8dp"
                android:text="취소"
                android:textSize="14sp"
                android:textColor="#FF4444"
                android:backgroundTint="#1E1E2E"
                android:stateListAnimator="@null"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 수동 모드 버튼 + LED -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/ledManual"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/led_off" />

            <Button
                android:id="@+id/btnManualMode"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="수동 연결"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:backgroundTint="#1E1E2E"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- 서버 목록 -->
        <Button
            android:id="@+id/btnServerList"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="📋  서버 목록 관리"
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#1E1E2E"
            android:stateListAnimator="@null" />

        <!-- 자동연결 아이콘 -->
        <Button
            android:id="@+id/btnAutoShortcut"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="⚡  바탕화면에 자동연결 아이콘 추가"
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#1E1E2E"
            android:stateListAnimator="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="수동 실행"
            android:textSize="12sp"
            android:textColor="#666666" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOpenVpn"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="🔒 OpenVPN"
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:backgroundTint="#1E1E2E"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnYoutubeMusic"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🎵 모프"
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:backgroundTint="#1E1E2E"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#0F0F1A"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="사용 방법"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF4444" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="1. ▶ 버튼: 자동으로 서버 찾아 연결\n2. 연결 성공 시 서버 자동 저장\n3. 수동 연결: 🔴불 켜지면 서버 목록에서 직접 선택\n4. 모프 종료 시 VPN 자동 해제"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
